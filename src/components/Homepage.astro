---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import BotanicalSprig from "./BotanicalSprig.astro";
import anim_test from "../images/anim_test.gif";
const { title } = Astro.props;

const pillars = [
  {
    title: "100% Botanical",
    body: "Every drop is built from organic essential oils, resins, and absolutes — never synthetic musks or fixatives.",
  },
  {
    title: "Small-Batch",
    body: "Blended by hand in batches of forty, then rested for six weeks so the notes can settle and marry.",
  },
  {
    title: "Kind by Nature",
    body: "Vegan, cruelty-free, and bottled in refillable amber glass. Good for your skin, gentle on the earth.",
  },
];

const notes = [
  {
    stage: "Top",
    label: "First Breath",
    items: ["Cold-pressed Bergamot", "Wild Neroli", "Green Cardamom"],
  },
  {
    stage: "Heart",
    label: "The Bloom",
    items: ["Damask Rose Otto", "Night Jasmine", "Orris Root"],
  },
  {
    stage: "Base",
    label: "The Earth",
    items: ["Mysore Sandalwood", "Smoked Vetiver", "Wild Oakmoss"],
  },
];

const steps = [
  { n: "01", title: "Harvest", body: "Flowers and roots gathered at dawn from organic, biodynamic growers." },
  { n: "02", title: "Distill", body: "Slow steam-distilled in copper, the old way, to keep the scent alive." },
  { n: "03", title: "Blend", body: "Layered by the nose alone — no formula software, only patience." },
  { n: "04", title: "Rest", body: "Aged six weeks in darkness before it ever meets your skin." },
];
---

<BaseLayout title={title} is404Page={false}>
  <main class="font-serif-body text-bark dark:text-[#e9e4d8]">
    <!-- Hero -->
    <section
      id="fragrance"
      class="relative grid gap-10 lg:gap-16 md:grid-cols-2 items-center py-10 md:py-16"
    >
      <div class="order-2 md:order-1 reveal">
        <p class="eyebrow eyebrow-rule text-sage-deep dark:text-sage mb-5">
          Drawn from the earth
        </p>
        <h1
          class="font-serif-display leading-[0.95] text-5xl sm:text-6xl md:text-7xl mb-6 text-olive dark:text-parchment"
        >
          A perfume that<br /><em class="not-italic text-terracotta">remembers</em> the soil it grew from.
        </h1>
        <p class="text-lg md:text-xl leading-relaxed max-w-md text-bark/80 dark:text-[#e9e4d8]/80 mb-8">
          Smara is an all-natural eau de parfum, handcrafted in small batches
          from organic botanicals. No synthetics, no shortcuts — only the raw,
          living scent of the wild.
        </p>
        <div class="flex flex-wrap gap-4 items-center">
          <a
            href="#ritual"
            class="focus-ring inline-block bg-olive dark:bg-sage text-parchment dark:text-forest px-7 py-3 rounded-full font-overpass-mono text-sm uppercase tracking-widest transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-10px_rgba(74,82,64,0.55)] dark:hover:shadow-[0_12px_28px_-10px_rgba(138,154,123,0.45)]"
          >
            Discover the scent
          </a>
          <a
            href="#craft"
            class="focus-ring inline-block border border-olive/40 dark:border-sage/40 px-7 py-3 rounded-full font-overpass-mono text-sm uppercase tracking-widest text-olive dark:text-sage transition-colors hover:bg-olive/5 dark:hover:bg-sage/10"
          >
            Our craft
          </a>
        </div>
      </div>
      <div class="order-1 md:order-2 relative reveal">
        <div
          class="absolute inset-0 -m-6 rounded-[40%_60%_55%_45%/55%_45%_60%_40%] bg-sage/20 dark:bg-sage/10 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <BotanicalSprig
          class="pointer-events-none absolute -left-6 -top-8 h-44 w-auto text-sage-deep/20 dark:text-sage/20 -rotate-[18deg]"
        />
        <BotanicalSprig
          class="pointer-events-none absolute -right-4 bottom-2 h-36 w-auto text-sage-deep/15 dark:text-sage/15 rotate-[200deg]"
        />
        <Image
          class="float relative w-full sm:h-[350px] lg:h-[600px] object-contain object-center"
          src={anim_test}
          alt="The Smara perfume bottle, hand-poured from organic botanicals"
        />
      </div>

      <!-- scroll cue -->
      <div
        class="pointer-events-none absolute inset-x-0 -bottom-2 hidden md:flex flex-col items-center gap-2 text-sage-deep dark:text-sage"
        aria-hidden="true"
      >
        <span class="eyebrow text-[0.6rem] opacity-70">Scroll</span>
        <span class="scroll-cue-track"><span class="scroll-cue-dot"></span></span>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="relative isolate overflow-hidden my-6 px-6 md:px-12 py-14 md:py-20 rounded-3xl bg-cream/50 dark:bg-bark/30">
      <BotanicalSprig
        class="pointer-events-none absolute -z-10 -right-10 -top-12 h-64 w-auto text-sage-deep/[7%] dark:text-sage/[7%] rotate-[24deg]"
      />
      <p class="eyebrow eyebrow-rule text-sage-deep dark:text-sage mb-4 reveal">Our philosophy</p>
      <h2
        class="font-serif-display text-3xl md:text-5xl max-w-2xl mb-12 text-olive dark:text-parchment reveal"
      >
        Made by hand. Grown, not engineered.
      </h2>
      <div class="grid gap-8 md:gap-12 md:grid-cols-3">
        {
          pillars.map((p, i) => (
            <div
              class="reveal group rounded-2xl p-5 -m-5 transition-all duration-300 hover:-translate-y-1 hover:bg-parchment/60 dark:hover:bg-forest/40"
              style={`--reveal-delay: ${i * 120}ms`}
            >
              <h3 class="font-serif-display text-2xl mb-3 text-terracotta">
                {p.title}
              </h3>
              <p class="leading-relaxed text-bark/75 dark:text-[#e9e4d8]/75">
                {p.body}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Ingredients / Notes pyramid -->
    <section
      id="ingredients"
      class="py-14 md:py-20 border-t border-bark/10 dark:border-sage/15"
    >
      <p class="eyebrow eyebrow-rule text-sage-deep dark:text-sage mb-4 reveal">The botanicals</p>
      <h2
        class="font-serif-display text-3xl md:text-5xl max-w-2xl mb-12 text-olive dark:text-parchment reveal"
      >
        Twelve raw ingredients. Nothing hidden.
      </h2>
      <div class="grid gap-px bg-bark/10 dark:bg-sage/15 md:grid-cols-3 rounded-2xl overflow-hidden">
        {
          notes.map((n, i) => (
            <div class="bg-parchment dark:bg-forest p-8 reveal" style={`--reveal-delay: ${i * 120}ms`}>
              <div class="flex items-baseline justify-between mb-5">
                <span class="font-serif-display text-2xl text-olive dark:text-sage">
                  {n.stage}
                </span>
                <span class="eyebrow text-sage-deep dark:text-sage">
                  {n.label}
                </span>
              </div>
              <ul class="space-y-2">
                {n.items.map((item) => (
                  <li class="text-lg text-bark/80 dark:text-[#e9e4d8]/80 border-b border-bark/5 dark:border-sage/10 pb-2 transition-colors duration-200 hover:text-terracotta dark:hover:text-terracotta hover:border-terracotta/30">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Craft process -->
    <section
      id="craft"
      class="relative isolate overflow-hidden my-6 px-6 md:px-12 py-14 md:py-20 rounded-3xl bg-cream/50 dark:bg-bark/30"
    >
      <BotanicalSprig
        class="pointer-events-none absolute -z-10 -left-12 -bottom-16 h-72 w-auto text-sage-deep/[7%] dark:text-sage/[7%] -rotate-[200deg]"
      />
      <p class="eyebrow eyebrow-rule text-sage-deep dark:text-sage mb-4 reveal">From flower to flacon</p>
      <h2
        class="font-serif-display text-3xl md:text-5xl max-w-2xl mb-12 text-olive dark:text-parchment reveal"
      >
        Four slow steps, the old way.
      </h2>
      <div class="grid gap-10 sm:grid-cols-2 md:grid-cols-4">
        {
          steps.map((s, i) => (
            <div
              class="reveal group rounded-2xl p-5 -m-5 transition-all duration-300 hover:-translate-y-1 hover:bg-parchment/60 dark:hover:bg-forest/40"
              style={`--reveal-delay: ${i * 120}ms`}
            >
              <span class="font-overpass-mono text-sm text-terracotta transition-opacity group-hover:opacity-100">
                {s.n}
              </span>
              <h3 class="font-serif-display text-2xl mt-2 mb-3 text-olive dark:text-parchment">
                {s.title}
              </h3>
              <p class="leading-relaxed text-bark/75 dark:text-[#e9e4d8]/75">
                {s.body}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Closing CTA -->
    <section
      id="ritual"
      class="relative isolate overflow-hidden py-16 md:py-24 mt-6 rounded-3xl bg-olive dark:bg-[#2a2f25] text-parchment text-center px-6 reveal"
    >
      <BotanicalSprig
        class="pointer-events-none absolute -z-10 -left-8 -top-10 h-56 w-auto text-parchment/[6%] rotate-[28deg]"
      />
      <BotanicalSprig
        class="pointer-events-none absolute -z-10 -right-8 -bottom-12 h-56 w-auto text-parchment/[6%] -rotate-[200deg]"
      />
      <p class="eyebrow eyebrow-rule text-sage mb-4 justify-center">Join the harvest</p>
      <h2 class="font-serif-display text-3xl md:text-5xl max-w-2xl mx-auto mb-5">
        Be first to know when the next batch is poured.
      </h2>
      <p class="max-w-md mx-auto text-parchment/80 mb-8 leading-relaxed">
        We make Smara only when the botanicals are at their finest. Leave your
        email and we'll write when a new harvest is ready.
      </p>
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto justify-center">
        <label class="sr-only" for="email">Email address</label>
        <input
          id="email"
          type="email"
          required
          placeholder="you@garden.com"
          class="focus-ring flex-1 rounded-full px-5 py-3 bg-parchment/95 text-bark font-overpass-mono text-sm outline-none placeholder:text-bark/40"
        />
        <button
          type="submit"
          class="focus-ring rounded-full px-7 py-3 bg-terracotta text-parchment font-overpass-mono text-sm uppercase tracking-widest transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5 hover:shadow-[0_12px_28px_-10px_rgba(181,115,79,0.6)]"
        >
          Notify me
        </button>
      </form>
    </section>

    <slot />
  </main>
</BaseLayout>
