---
import ThemeToggle from "./ThemeToggle.astro";
const { is404Page = false } = Astro.props;
---

<header
  id="site-header"
  class="sticky top-0 z-40 -mx-8 md:-mx-16 px-8 md:px-16 py-3 mb-[14px] -mt-8 md:-mt-8 border-b border-transparent transition-all duration-300"
>
  <nav class="relative flex items-center justify-between w-full h-[30px]">
    {
      !is404Page && (
        <div class="flex items-baseline h-[30px]">
          <a href="/" class="block">
            <span class="link-underline font-serif-display text-2xl tracking-wide text-olive dark:text-sage">
              Smara
            </span>
          </a>
        </div>
      )
    }
    {
      !is404Page && (
        <span class="eyebrow hidden sm:inline absolute left-1/2 -translate-x-1/2 text-sage-deep dark:text-sage">
          Organic Perfumery
        </span>
      )
    }
    <div class="flex items-center h-[30px] gap-2">
      {
        !is404Page && (
          <>
            <div class="flex items-center justify-center h-[30px] w-[30px]">
              <ThemeToggle />
            </div>
          </>
        )
      }
    </div>
  </nav>
  <slot />
</header>

<script>
  function setupHeaderScroll() {
    const header = document.getElementById("site-header");
    if (!header) return;
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 16);
    };
    onScroll();
    // remove any listener left from a previous page-load (view transitions)
    window.removeEventListener("scroll", (window as any).__smaraHeaderScroll);
    (window as any).__smaraHeaderScroll = onScroll;
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  document.addEventListener("astro:page-load", setupHeaderScroll);
</script>
