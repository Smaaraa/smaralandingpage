---
import Navigation from "./Navigation.astro";
import ThemeToggle from "./ThemeToggle.astro";
const { is404Page = false } = Astro.props;
---

<header class="mb-[20px] mt-[-10px]">
  <nav class="flex items-center justify-between w-full h-[30px]">
    {
      !is404Page && (
        <div class="flex items-baseline h-[30px] gap-2">
          <a href="/" class="block">
            <span class="font-serif-display text-2xl tracking-wide text-olive dark:text-sage">
              Smara
            </span>
          </a>
          <span class="eyebrow hidden sm:inline text-sage-deep dark:text-sage">
            Organic Perfumery
          </span>
        </div>
      )
    }
    <div class="flex items-center h-[30px] gap-2">
      {
        !is404Page && (
          <>
            <div class="flex items-center justify-center h-[30px] w-[30px]">
              <ThemeToggle />
            </div>
          </>
        )
      }
    </div>
  </nav>
  {
    !is404Page && (
      <div class="absolute right-0 mt-2">
        <Navigation />
      </div>
    )
  }
  <slot />
</header>
