---
const today = new Date();
import { Icon } from "astro-icon/components";
---

<footer class="w-full mt-16">
  <div class="border-t border-bark/10 dark:border-sage/15 pt-8">
    <!-- brand mark + tagline -->
    <div class="flex flex-col items-center gap-1 mb-6 text-center">
      <span
        class="font-serif-display italic text-3xl leading-none text-olive dark:text-sage"
        aria-hidden="true"
      >
        S
      </span>
      <span class="eyebrow text-sage-deep dark:text-sage">
        Drawn from the earth
      </span>
    </div>

    <div
      class="md:flex md:justify-between md:items-center font-overpass-mono w-full gap-4"
    >
      <div class="text-[12px] text-center md:text-left flex justify-center md:justify-start text-sage-deep dark:text-sage">
        &copy; {today.getFullYear()} Smara — Handcrafted in small batches from organic botanicals.
      </div>
      <div class="flex justify-center gap-4 m-3 sm:m-0 text-olive dark:text-sage">
        <a href="" target="_blank" class="transition-opacity hover:opacity-60">
          <span class="sr-only">Instagram Profile</span>
          <Icon name="mdi:instagram" class="h-[20px] w-[20px]" />
        </a>
        <a href="" target="_blank" class="transition-opacity hover:opacity-60">
          <span class="sr-only">Leaf — naturally sourced</span>
          <Icon name="mdi:leaf" class="h-[20px] w-[20px]" />
        </a>
      </div>
    </div>
  </div>
  <slot />
</footer>