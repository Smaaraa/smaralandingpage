---
const today = new Date();
import { Icon } from "astro-icon/components";
---

<footer
  class="md:flex md:justify-between md:items-center md:align-center font-overpass-mono w-full md:h-full mt-12"
>
  <div class="text-[12px] text-center items-center flex justify-center text-sage-deep dark:text-sage">
    &copy; {today.getFullYear()} Smara — Handcrafted in small batches from organic botanicals.
  </div>
  <div class="flex justify-center gap-3 m-2 sm:m-0 text-olive dark:text-sage">
    <a href="" target="_blank" class="transition-opacity hover:opacity-60">
      <span class="sr-only">Instagram Profile</span>
      <Icon name="mdi:instagram" class="h-[20px] w-[20px]" />
    </a>
    <a href="" target="_blank" class="transition-opacity hover:opacity-60">
      <span class="sr-only">Leaf — naturally sourced</span>
      <Icon name="mdi:leaf" class="h-[20px] w-[20px]" />
    </a>
  </div>
  <slot />
</footer>